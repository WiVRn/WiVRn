#: client/scenes/lobby_gui.cpp:916 client/scenes/stream_gui.cpp:444
msgid ""
"Reduce flicker for high contrast edges.\n"
"Useful when the input resolution is high compared to the headset display"
msgstr ""
"Riduce i lampeggiamenti sui bordi ad alto contrasto.\n"
"Utile quando la risoluzine d'entrata è alta in confronto a quella del visore"

#: client/scenes/lobby_gui.cpp:921 client/scenes/stream_gui.cpp:449
msgid "Sharpening"
msgstr "Miglioramento della nitidezza"

#: client/scenes/lobby_gui.cpp:941 client/scenes/stream_gui.cpp:470
msgid ""
"Improve clarity of high contrast edges and counteract blur.\n"
"Useful when the input resolution is low compared to the headset display"
msgstr ""
"Migliora la nitidezza dei bordi ad alto contrasto e riduce la sfocatura.\n"
"Utile quando la risoluzione d'entrate è bassa in contronto a quella del "
"visore"

