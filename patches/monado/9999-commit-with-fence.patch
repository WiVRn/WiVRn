  *
@@ -220,6 +302,29 @@ submit_fence(struct client_vk_compositor *c, xrt_result_t *out_xret)
 		return false;
 	}
 
+	if (c->fences[c->current_fence].fence != VK_NULL_HANDLE)
+	{
+		vk->vkResetFences(vk->device, 1, &c->fences[c->current_fence].fence);
+		COMP_TRACE_IDENT(submit_fence);
+		c->current_fence = (c->current_fence + 1) % ARRAY_SIZE(c->fences);
+		vk_queue_lock(vk->main_queue);
+
+		ret = vk->vkQueueSubmit(                //
+		    vk->main_queue->queue,              // queue
+		    0,                                  // submitCount
+		    NULL,                               // pSubmits
+		    c->fences[c->current_fence].fence); // fence
+
+		vk_queue_unlock(vk->main_queue);
+
+		if (ret != VK_SUCCESS) {
+			VK_ERROR(vk, "vkQueueSubmit: %s", vk_result_string(ret));
+		} else {
+			*out_xret = xrt_comp_layer_commit_with_fence(&c->xcn->base, c->fences[c->current_fence].xcf);
+		}
+		return true;
+	}
+
 	{
 		COMP_TRACE_IDENT(create_and_submit_fence);
 
@@ -392,6 +497,15 @@ client_vk_compositor_destroy(struct xrt_compositor *xc)
 	}
 	xrt_compositor_semaphore_reference(&c->sync.xcsem, NULL);
 
+	for (size_t i = 0; i < ARRAY_SIZE(c->fences); i++) {
+		if (c->fences[i].fence != VK_NULL_HANDLE) {
+			vk->vkDestroyFence(vk->device, c->fences[i].fence, NULL);
+		}
+		if (c->fences[i].xcf) {
+			xrt_compositor_fence_reference(&c->fences[i].xcf, NULL);
+		}
+	}
+
 	// Now safe to free the pool.
 	vk_cmd_pool_destroy(vk, &c->pool);
 
@@ -881,8 +995,14 @@ client_vk_compositor_create(struct xrt_compositor_native *xcn,
 		if (xret != XRT_SUCCESS) {
 			goto err_pool;
 		}
-	}
+	} else
 #endif
+	{
+		xret = setup_fences(c);
+		if (xret != XRT_SUCCESS) {
+			goto err_pool;
+		}
+	}
 
 	// Get max texture size.
 	{
