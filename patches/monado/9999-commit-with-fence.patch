+/*
+ *
+ * Compositor fence functions.
+ *
+ */
+
+
+xrt_result_t
+ipc_handle_compositor_fence_import(volatile struct ipc_client_state *ics,
+                                   uint32_t *out_id,
+                                   const xrt_graphics_sync_handle_t *handles,
+                                   const uint32_t handle_count)
+{
+	xrt_result_t xret;
+
+	if (ics->xc == NULL) {
+		return XRT_ERROR_IPC_SESSION_NOT_CREATED;
+	}
+
+	size_t id = 0;
+	for (; id < ARRAY_SIZE(ics->xcfs); id++) {
+		if (ics->xcfs[id] == NULL) {
+			break;
+		}
+	}
+
+	if (id == ARRAY_SIZE(ics->xcfs)) {
+		IPC_ERROR(ics->server, "Too many compositor fences alive!");
+		return XRT_ERROR_IPC_FAILURE;
+	}
+
+	struct xrt_compositor_fence * xcf;
+	xret = xrt_comp_import_fence(ics->xc, *handles, &xcf);
+	if (xret != XRT_SUCCESS) {
+		IPC_ERROR(ics->server, "Failed to import compositor fence!");
+		return xret;
+	}
+
+	ics->xcfs[id] = xcf;
+	*out_id = id;
+
+	return XRT_SUCCESS;
+}
+
+xrt_result_t
+ipc_handle_compositor_fence_destroy(volatile struct ipc_client_state *ics,
+                                    uint32_t id)
+{
+	if (ics->xc == NULL) {
+		return XRT_ERROR_IPC_SESSION_NOT_CREATED;
+	}
+
+	if (ics->xcfs[id] == NULL) {
+		IPC_ERROR(ics->server, "Client tried to delete non-existent compositor fence!");
+		return XRT_ERROR_IPC_FAILURE;
+	}
+
+	xrt_compositor_fence_reference((struct xrt_compositor_fence**)&ics->xcfs[id], NULL);
+	return XRT_SUCCESS;
+}
