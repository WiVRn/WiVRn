+xrt_result_t
+ipc_handle_compositor_layer_sync_with_fence(volatile struct ipc_client_state *ics,
+                                                uint32_t slot_id,
+                                                uint32_t fence_id,
+                                                uint32_t *out_free_slot_id)
+{
+	IPC_TRACE_MARKER();
+
+	if (ics->xc == NULL) {
+		return XRT_ERROR_IPC_SESSION_NOT_CREATED;
+	}
+	if (fence_id >= ARRAY_SIZE(ics->xcfs)) {
+		IPC_ERROR(ics->server, "Invalid fence_id");
+		return XRT_ERROR_IPC_FAILURE;
+	}
+	if (ics->xcfs[fence_id] == NULL) {
+		IPC_ERROR(ics->server, "Fence of id %u not created!", fence_id);
+		return XRT_ERROR_IPC_FAILURE;
+	}
+
+	struct xrt_compositor_fence *xcf = ics->xcfs[fence_id];
+
+	struct ipc_shared_memory *ism = get_ism(ics);
+	struct ipc_layer_slot *slot = &ism->slots[slot_id];
+
+	// Copy current slot data.
+	struct ipc_layer_slot copy = *slot;
+
+
+
+	/*
+	 * Transfer data to underlying compositor.
+	 */
+
+	xrt_comp_layer_begin(ics->xc, &copy.data);
+
+	_update_layers(ics, ics->xc, &copy);
+
+	xrt_comp_layer_commit_with_fence(ics->xc, xcf);
+
+
+	/*
+	 * Manage shared state.
+	 */
+
+	os_mutex_lock(&ics->server->global_state.lock);
+
+	*out_free_slot_id = (ics->server->current_slot_index + 1) % IPC_MAX_SLOTS;
+	ics->server->current_slot_index = *out_free_slot_id;
+
+	os_mutex_unlock(&ics->server->global_state.lock);
+
+	return XRT_SUCCESS;
+}
