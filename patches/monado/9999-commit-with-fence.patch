+static xrt_result_t
+multi_compositor_layer_commit_with_fence(struct xrt_compositor *xc, struct xrt_compositor_fence *xcf)
+{
+	COMP_TRACE_MARKER();
+
+	struct multi_compositor *mc = multi_compositor(xc);
+	int64_t frame_id = mc->progress.data.frame_id;
+
+	push_fence_to_wait_thread(mc, frame_id, xcf);
+
+	return XRT_SUCCESS;
+}
