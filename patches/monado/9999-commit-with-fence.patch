diff --git a/src/xrt/ipc/client/ipc_client_compositor.c b/src/xrt/ipc/client/ipc_client_compositor.c
index 4fc89d529..fc13d61ba 100644
--- a/src/xrt/ipc/client/ipc_client_compositor.c
+++ b/src/xrt/ipc/client/ipc_client_compositor.c
@@ -105,6 +105,18 @@ struct ipc_client_compositor_semaphore
 	uint32_t id;
 };
 
+/*!
+ * Client proxy for an xrt_compositor_fence implementation over IPC.
+ * @implements xrt_compositor_fence
+ */
+struct ipc_client_compositor_fence
+{
+	struct xrt_compositor_fence base;
+
+	struct ipc_client_compositor *icc;
+
+	uint32_t id;
+};
 
 /*
  *
@@ -130,6 +142,12 @@ ipc_client_compositor_semaphore(struct xrt_compositor_semaphore *xcsem)
 	return (struct ipc_client_compositor_semaphore *)xcsem;
 }
 
+static inline struct ipc_client_compositor_fence*
+ipc_client_compositor_fence(struct xrt_compositor_fence *xcf)
+{
+	return (struct ipc_client_compositor_fence *)xcf;
+}
+
 
 /*
  *
@@ -208,6 +226,38 @@ ipc_compositor_swapchain_release_image(struct xrt_swapchain *xsc, uint32_t index
 	IPC_CHK_ALWAYS_RET(icc->ipc_c, xret, "ipc_call_swapchain_release_image");
 }
 
+/*
+ *
+ * Compositor fence functions.
+ *
+ */
+
+static xrt_result_t
+ipc_client_compositor_fence_wait(struct xrt_compositor_fence *xcf, uint64_t timeout_ns)
+{
+	struct ipc_client_compositor_fence *iccf = ipc_client_compositor_fence(xcf);
+	struct ipc_client_compositor *icc = iccf->icc;
+
+	IPC_ERROR(icc->ipc_c, "Cannot call wait on client side!");
+
+	return XRT_ERROR_IPC_FAILURE;
+}
+
+static void
+ipc_client_compositor_fence_destroy(struct xrt_compositor_fence *xcf)
+{
+	struct ipc_client_compositor_fence *iccf = ipc_client_compositor_fence(xcf);
+	struct ipc_client_compositor *icc = iccf->icc;
+	xrt_result_t xret;
+
+	xret = ipc_call_compositor_fence_destroy(icc->ipc_c, iccf->id);
+
+	// Can't return anything here, just continue.
+	IPC_CHK_ONLY_PRINT(icc->ipc_c, xret, "ipc_call_compositor_fence_destroy");
+
+	free(iccf);
+}
+
 
 /*
  *
@@ -470,6 +520,30 @@ ipc_compositor_swapchain_import(struct xrt_compositor *xc,
 	return swapchain_server_import(icc, info, native_images, image_count, out_xsc);
 }
 
+static xrt_result_t
+ipc_compositor_fence_import(struct xrt_compositor *xc,
+                            xrt_graphics_sync_handle_t handle,
+                            struct xrt_compositor_fence **out_xcf)
+{
+	struct ipc_client_compositor *icc = ipc_client_compositor(xc);
+	xrt_result_t xret;
+	uint32_t id = 0;
+
+	xret = ipc_call_compositor_fence_import(icc->ipc_c, &handle, 1, &id);
+	IPC_CHK_AND_RET(icc->ipc_c, xret, "ipc_call_compositor_fence_import");
+
+	struct ipc_client_compositor_fence *iccf = U_TYPED_CALLOC(struct ipc_client_compositor_fence);
+	iccf->base.reference.count = 1;
+	iccf->base.wait = ipc_client_compositor_fence_wait;
+	iccf->base.destroy = ipc_client_compositor_fence_destroy;
+	iccf->id = id;
+	iccf->icc = icc;
+
+	*out_xcf = &iccf->base;
+
+	return XRT_SUCCESS;
+}
+
 static xrt_result_t
 ipc_compositor_semaphore_create(struct xrt_compositor *xc,
                                 xrt_graphics_sync_handle_t *out_handle,
@@ -774,6 +848,38 @@ ipc_compositor_layer_commit(struct xrt_compositor *xc, xrt_graphics_sync_handle_
 	return xret;
 }
 
+static xrt_result_t
+ipc_compositor_layer_commit_with_fence(struct xrt_compositor *xc,
+                                           struct xrt_compositor_fence* xcf)
+{
+	struct ipc_client_compositor *icc = ipc_client_compositor(xc);
+	struct ipc_client_compositor_fence *iccf = ipc_client_compositor_fence(xcf);
+	xrt_result_t xret;
+
+	struct ipc_shared_memory *ism = icc->ipc_c->ism;
+	struct ipc_layer_slot *slot = &ism->slots[icc->layers.slot_id];
+
+	// Last bit of data to put in the shared memory area.
+	slot->layer_count = icc->layers.layer_count;
+
+	xret = ipc_call_compositor_layer_sync_with_fence( //
+	    icc->ipc_c,                                       //
+	    icc->layers.slot_id,                              //
+	    iccf->id,                                         //
+	    &icc->layers.slot_id);                            //
+
+	/*
+	 * We are probably in a really bad state if we fail, at
+	 * least print out the error and continue as best we can.
+	 */
+	IPC_CHK_ONLY_PRINT(icc->ipc_c, xret, "ipc_call_compositor_layer_sync_with_semaphore");
+
+	// Reset.
+	icc->layers.layer_count = 0;
+
+	return xret;
+}
+
