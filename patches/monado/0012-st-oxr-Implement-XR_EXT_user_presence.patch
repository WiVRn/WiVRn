-	XRT_SESSION_EVENT_VISIBILITY_MASK_CHANGE = 9
+	XRT_SESSION_EVENT_VISIBILITY_MASK_CHANGE = 9,
+
+	//! User presence has changed (hmd may have been put on or removed)
+	XRT_SESSION_EVENT_USER_PRESENCE_CHANGE = 10,
 };
 
