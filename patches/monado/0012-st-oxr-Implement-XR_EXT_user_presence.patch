+			bool presence = false;
+			if (xrt_device_get_presence(xdev, &presence) == XRT_SUCCESS)
+				oxr_event_push_XrEventDataUserPresenceChangedEXT(log, sess, presence);
+			else
+				oxr_warn(log, "Call to xrt_device_get_presence failed.");
+		}
+#endif
 	} else {
 		// Headless, pretend we got event from the compositor.
 		sess->compositor_visible = true;
@@ -480,7 +491,13 @@ oxr_session_poll(struct oxr_logger *log, struct oxr_session *sess)
